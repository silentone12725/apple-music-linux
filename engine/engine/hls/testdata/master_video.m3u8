# master_video.m3u8
# Master playlist with 2 video variants and 2 audio alternatives.
# Tests SelectVideoVariant (by height in _WxH_ path segment) and
# SelectAudioVariant (by GroupID priority + _grN_ rank).
#   - Video 1920x1080 @ 5Mbps  (path contains _1920x1080)
#   - Video 1280x720  @ 3Mbps  (path contains _1280x720)
#   - Audio alt group "audio-stereo-256" (URI has _gr1_)
#   - Audio alt group "audio-atmos"      (URI has _gr3_)
#EXTM3U
#EXT-X-MEDIA:TYPE=AUDIO,GROUP-ID="audio-stereo-256",NAME="Stereo",URI="audio_stereo_gr1_.m3u8"
#EXT-X-MEDIA:TYPE=AUDIO,GROUP-ID="audio-atmos",NAME="Atmos",URI="audio_atmos_gr3_.m3u8"
#EXT-X-STREAM-INF:BANDWIDTH=5000000,AVERAGE-BANDWIDTH=5000000,CODECS="avc1.640028,mp4a.40.2",RESOLUTION=1920x1080,AUDIO="audio-stereo-256"
video_1920x1080.m3u8
#EXT-X-STREAM-INF:BANDWIDTH=3000000,AVERAGE-BANDWIDTH=3000000,CODECS="avc1.64001f,mp4a.40.2",RESOLUTION=1280x720,AUDIO="audio-stereo-256"
video_1280x720.m3u8
