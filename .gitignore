# ── Build outputs ─────────────────────────────────────────────────────────────
node_modules/

# AppImage releases (large binary, distributed separately)
*.AppImage

# Electron: auto-generated JS bundles (rebuilt by esbuild from src/)
electron/engine-bundle.js
electron/engine-sse-bundle.js
electron/renderer-bundle.js
electron/smart-cache-bundle.js
electron/vision-bundle.js
electron/engine-playback.bundle.js
electron/engine-sse.bundle.js
electron/smart-cache.bundle.js
electron/vision-glass.bundle.js

# Electron dist/resources/app: all JS/CJS/MJS are copies of source or generated
# bundles. Only package.json is committed; everything else is produced by the
# build step (esbuild + file copy).
electron/dist/resources/app/*.js
electron/dist/resources/app/*.mjs
electron/dist/resources/app/*.cjs
# Build artifacts — generated by build.sh / npm run dist / go build
electron/dist/linux-unpacked/
electron/dist/resources/vlc/
electron/dist/resources/app/engine
electron/dist/resources/drm

# ── Go binaries ───────────────────────────────────────────────────────────────
# Engine build artefacts (compiled by `go build ./engine`)
apple-music-cli
engine/apple-music-cli
engine/main
engine/bench
engine/startupbench
engine/drmcheck
engine/drminspect
engine/hlscompare
engine/mvcompare
engine/parity
engine/qacompare
engine/playcheck
engine/protoinspect
engine/mockwrapper
engine/test-server
# Any stray test binary at repo root
test_bin

# Go workspace sum (generated, not source of truth)
go.work.sum

# ── Engine config ─────────────────────────────────────────────────────────────
# config.yaml.example IS committed; the live file with tokens is not
engine/config.yaml

# ── DRM / Android container runtime state ─────────────────────────────────────
