drm/rootfs/data/data/com.apple.android.music/files/STOREFRONT_ID
drm/rootfs/data/data/com.apple.android.music/files/adi.pb
drm/rootfs/data/data/com.apple.android.music/files/fsi.pdat
drm/rootfs/data/data/com.apple.android.music/files/IC-Info.sids
drm/rootfs/data/data/com.apple.android.music/files/engine-session.lock
drm/rootfs/data/data/com.apple.android.music/files/mpl_db/
drm/rootfs/home/
drm/rootfs/tmp/

