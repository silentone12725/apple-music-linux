# ── Build outputs ─────────────────────────────────────────────────────────────
node_modules/

# Electron: auto-generated JS bundles (rebuilt by esbuild from src/)
electron/engine-bundle.js
electron/engine-sse-bundle.js
electron/renderer-bundle.js
electron/smart-cache-bundle.js
electron/vision-bundle.js

# Electron dist/resources/app: all JS/CJS/MJS are copies of source or generated
# bundles. Only package.json is committed; everything else is produced by the
# build step (esbuild + file copy).
electron/dist/resources/app/*.js
electron/dist/resources/app/*.mjs
electron/dist/resources/app/*.cjs

# ── Go binaries ───────────────────────────────────────────────────────────────
# CLI / engine build artefacts (compiled by `go build ./cli`)
apple-music-cli
cli/apple-music-cli
cli/main
cli/bench
cli/startupbench
cli/drmcheck
cli/drminspect
cli/hlscompare
cli/mvcompare
cli/parity
cli/qacompare
cli/playcheck
cli/protoinspect
cli/mockwrapper
cli/test-server
# Any stray test binary at repo root
test_bin

# Go workspace sum (generated, not source of truth)
go.work.sum

# ── Engine CLI config ─────────────────────────────────────────────────────────
# config.yaml.example IS committed; the live file with tokens is not
cli/config.yaml

